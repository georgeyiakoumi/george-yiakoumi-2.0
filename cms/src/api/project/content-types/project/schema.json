{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": false
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "project_thumb": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "date": {
      "type": "date"
    },
    "tags": {
      "type": "customField",
      "customField": "plugin::tagsinput.tags"
    },
    "tools": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::tool.tool"
    },
    "project_client": {
      "type": "string"
    },
    "project_role": {
      "type": "string"
    },
    "body": {
      "type": "dynamiczone",
      "components": [
        "project-blocks.video",
        "project-blocks.stats",
        "project-blocks.rich-text",
        "project-blocks.image",
        "project-blocks.comparison-slider",
        "project-blocks.carousel"
      ]
    }
  }
}
